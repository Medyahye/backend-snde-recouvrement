# --- Django ---
DJANGO_SECRET_KEY=change-me-in-prod-please-use-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SUPERUSER_EMAIL=admin@snde.local
DJANGO_SUPERUSER_PASSWORD=admin

# --- PostgreSQL ---
POSTGRES_DB=snde
POSTGRES_USER=snde
POSTGRES_PASSWORD=snde
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FAB=fab-imports
MINIO_BUCKET_PHOTOS=meter-photos
MINIO_USE_SSL=0

# --- Upload FAB ---
FAB_MAX_UPLOAD_SIZE=209715200
# 1 = la date du fichier doit être celle du jour (production). 0 = accepte toute date (dev/test).
FAB_REQUIRE_TODAY_DATE=1

# --- AWS S3 (source externe des FABs SNDE) ---
# Read-only IAM credentials. Mettre les vraies valeurs ICI dans le .env local
# (jamais commité). Ne JAMAIS partager ces clés dans des chats, logs ou commits.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=snde-facture
AWS_S3_REGION=eu-west-1
AWS_S3_PREFIX=Solde/
# Seuil sous lequel un FAB est considéré "vide" (nb min de lignes valides $$ ≥ 35 cols)
FAB_EMPTY_MIN_VALID_LINES=100

# --- Scoring ---
# formula = score metier; ft_transformer = modele IA livre dans backend/gnn_models
SCORING_ENGINE=ft_transformer
